# === Database (SQL Server 2019) ===
DB_USER="sa"
DB_PASSWORD="your-db-password"
DB_NAME="SixDegreesWiki"
DB_SERVER="localhost"

# === Redis ===
REDIS_URL="redis://localhost:6379"

# === NextAuth.js v5 ===
# Sinh random secret bang lenh: npx auth secret
NEXTAUTH_SECRET="your-nextauth-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# === OAuth: GitHub ===
# Huong dan lay key:
# 1. Truy cap https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Dien:
#    - Application name: Six Degrees of Wikipedia (Dev)
#    - Homepage URL: http://localhost:3000
#    - Authorization callback URL: http://localhost:3000/api/auth/callback/github
# 4. Click "Register application"
# 5. Copy Client ID va tao Client Secret
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# === OAuth: Google ===
# Huong dan lay key:
# 1. Truy cap https://console.cloud.google.com/apis/credentials
# 2. Tao project moi (hoac chon project co san)
# 3. Click "Create Credentials" -> "OAuth client ID"
# 4. Chon Application type: "Web application"
# 5. Dien:
#    - Name: Six Degrees of Wikipedia (Dev)
#    - Authorized JavaScript origins: http://localhost:3000
#    - Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
# 6. Click "Create"
# 7. Copy Client ID va Client Secret
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
